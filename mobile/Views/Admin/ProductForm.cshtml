@model AdminProductFormViewModel

@{
    Layout = "_AdminLayout";
    var isEdit = Model.ProductId.HasValue;
    ViewData["Title"] = isEdit ? "Sửa sản phẩm" : "Thêm sản phẩm";
    var formAction = isEdit ? "EditProduct" : "CreateProduct";
}

<div class="space-y-6">
    <section class="rounded-xl border border-border bg-card p-5 shadow-xs">
        <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
            <div>
                <p class="text-[11px] font-semibold uppercase tracking-widest text-muted-foreground">Catalog</p>
                <h2 class="mt-2 text-2xl font-bold tracking-tight text-foreground">@ViewData["Title"]</h2>
                <p class="mt-2 text-sm text-muted-foreground">Một sản phẩm có thể có nhiều ảnh. Ảnh được đánh dấu chính sẽ dùng làm ảnh đại diện.</p>
            </div>
            <a href="@Url.Action("Products", "Admin")" class="inline-flex w-fit items-center justify-center rounded-md border bg-background px-4 py-2 text-sm font-medium transition-all hover:bg-accent hover:text-accent-foreground">Quay lại danh sách</a>
        </div>
    </section>

    <form asp-controller="Admin" asp-action="@formAction" asp-route-id="@Model.ProductId" method="post" enctype="multipart/form-data" class="grid grid-cols-1 gap-6 xl:grid-cols-12">
        @Html.AntiForgeryToken()

        <div class="space-y-6 xl:col-span-8">
            <section class="rounded-xl border border-border bg-card p-5 shadow-xs">
                <h3 class="text-base font-semibold text-foreground">Thông tin sản phẩm</h3>
                <div asp-validation-summary="ModelOnly" class="mt-3 rounded-md border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-700"></div>

                <div class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-2">
                    <div class="md:col-span-2">
                        <label asp-for="Name" class="mb-2 block text-sm font-medium text-foreground">Tên sản phẩm</label>
                        <input asp-for="Name" class="h-10 w-full rounded-md border border-input bg-background px-3 text-sm text-foreground outline-none transition-colors focus:border-primary">
                        <span asp-validation-for="Name" class="mt-1 block text-sm text-rose-600"></span>
                    </div>

                    <div>
                        <label asp-for="Brand" class="mb-2 block text-sm font-medium text-foreground">Thương hiệu</label>
                        <input asp-for="Brand" class="h-10 w-full rounded-md border border-input bg-background px-3 text-sm text-foreground outline-none transition-colors focus:border-primary">
                    </div>

                    <div>
                        <label asp-for="CategoryId" class="mb-2 block text-sm font-medium text-foreground">Danh mục</label>
                        <select asp-for="CategoryId" class="h-10 w-full rounded-md border border-input bg-background px-3 text-sm text-foreground outline-none transition-colors focus:border-primary">
                            <option value="">Chưa phân loại</option>
                            @foreach (var category in Model.Categories)
                            {
                                <option value="@category.CategoryId">@category.CategoryName</option>
                            }
                        </select>
                    </div>

                    <div>
                        <label asp-for="NewCategoryName" class="mb-2 block text-sm font-medium text-foreground">Hoặc tạo danh mục mới</label>
                        <input asp-for="NewCategoryName" class="h-10 w-full rounded-md border border-input bg-background px-3 text-sm text-foreground outline-none transition-colors focus:border-primary" placeholder="Ví dụ: Laptop gaming">
                    </div>

                    <div>
                        <label asp-for="Stock" class="mb-2 block text-sm font-medium text-foreground">Tồn kho</label>
                        <input asp-for="Stock" type="number" min="0" class="h-10 w-full rounded-md border border-input bg-background px-3 text-sm text-foreground outline-none transition-colors focus:border-primary">
                        <span asp-validation-for="Stock" class="mt-1 block text-sm text-rose-600"></span>
                    </div>

                    <div>
                        <label asp-for="Price" class="mb-2 block text-sm font-medium text-foreground">Giá bán</label>
                        <input asp-for="Price" type="number" min="0" step="1000" class="h-10 w-full rounded-md border border-input bg-background px-3 text-sm text-foreground outline-none transition-colors focus:border-primary">
                        <span asp-validation-for="Price" class="mt-1 block text-sm text-rose-600"></span>
                    </div>

                    <div>
                        <label asp-for="Discount" class="mb-2 block text-sm font-medium text-foreground">Giảm giá (%)</label>
                        <input asp-for="Discount" type="number" min="0" max="100" step="0.1" class="h-10 w-full rounded-md border border-input bg-background px-3 text-sm text-foreground outline-none transition-colors focus:border-primary">
                        <span asp-validation-for="Discount" class="mt-1 block text-sm text-rose-600"></span>
                    </div>

                    <div class="md:col-span-2">
                        <label asp-for="Description" class="mb-2 block text-sm font-medium text-foreground">Mô tả</label>
                        <textarea asp-for="Description" rows="6" class="w-full rounded-md border border-input bg-background px-3 py-2 text-sm text-foreground outline-none transition-colors focus:border-primary"></textarea>
                    </div>
                </div>
            </section>

            <section class="rounded-xl border border-border bg-card p-5 shadow-xs">
                <h3 class="text-base font-semibold text-foreground">Ảnh sản phẩm</h3>
                <p class="mt-1 text-sm text-muted-foreground">Có thể chọn nhiều ảnh cùng lúc. Ảnh đầu tiên sẽ tự làm ảnh chính nếu sản phẩm chưa có ảnh chính.</p>

                <div class="mt-5 grid grid-cols-1 gap-4">
                    <div>
                        <label asp-for="UploadedImages" class="mb-2 block text-sm font-medium text-foreground">Upload ảnh mới</label>
                        <input asp-for="UploadedImages" type="file" multiple accept="image/png,image/jpeg,image/webp,image/gif" class="block w-full rounded-md border border-input bg-background px-3 py-2 text-sm text-foreground file:mr-4 file:rounded-md file:border-0 file:bg-primary file:px-3 file:py-2 file:text-sm file:font-medium file:text-primary-foreground">
                        <span asp-validation-for="UploadedImages" class="mt-1 block text-sm text-rose-600"></span>
                    </div>

                    <div>
                        <label asp-for="Thumbnail" class="mb-2 block text-sm font-medium text-foreground">URL ảnh đại diện thủ công</label>
                        <input asp-for="Thumbnail" class="h-10 w-full rounded-md border border-input bg-background px-3 text-sm text-foreground outline-none transition-colors focus:border-primary" placeholder="~/assets/img/product/product-1.jpg">
                        <p class="mt-1 text-xs text-muted-foreground">Nếu có ảnh upload, hệ thống sẽ tự đồng bộ ảnh chính vào trường này.</p>
                    </div>
                </div>
            </section>
        </div>

        <aside class="space-y-6 xl:col-span-4">
            <section class="rounded-xl border border-border bg-card p-5 shadow-xs">
                <h3 class="text-base font-semibold text-foreground">Xuất bản</h3>
                <label class="mt-4 flex items-center gap-3 rounded-md border border-border bg-background px-3 py-3 text-sm text-foreground">
                    <input asp-for="IsActive" type="checkbox" class="h-4 w-4 rounded border-input text-primary">
                    <span>Hiển thị sản phẩm trên cửa hàng</span>
                </label>

                <div class="mt-5 flex gap-2">
                    <button type="submit" class="inline-flex flex-1 items-center justify-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground transition-all hover:bg-primary/90">Lưu sản phẩm</button>
                    @if (isEdit)
                    {
                        <a href="@Url.Action("Product", "Shop", new { id = Model.ProductId })" class="inline-flex items-center justify-center rounded-md border bg-background px-4 py-2 text-sm font-medium transition-all hover:bg-accent hover:text-accent-foreground">Xem</a>
                    }
                </div>
            </section>

            @if (isEdit)
            {
                <section class="rounded-xl border border-border bg-card p-5 shadow-xs">
                    <h3 class="text-base font-semibold text-foreground">Thư viện ảnh</h3>

                    @if (Model.ExistingImages.Count == 0)
                    {
                        <p class="mt-4 rounded-md border border-dashed border-border px-4 py-6 text-center text-sm text-muted-foreground">Sản phẩm này chưa có ảnh phụ.</p>
                    }
                    else
                    {
                        <div class="mt-4 grid grid-cols-1 gap-3">
                            @foreach (var image in Model.ExistingImages)
                            {
                                <article class="rounded-md border border-border bg-background p-3">
                                    <img src="@Url.Content(image.ImageUrl ?? "~/assets/img/product/product-1.jpg")" alt="Ảnh sản phẩm" class="h-40 w-full rounded-md object-cover">
                                    <div class="mt-3 flex items-center justify-between gap-2">
                                        @if (image.IsMain == true)
                                        {
                                            <span class="inline-flex rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-700">Ảnh chính</span>
                                        }
                                        else
                                        {
                                            <form asp-controller="Admin" asp-action="SetMainProductImage" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="imageId" value="@image.ImageId">
                                                <button type="submit" class="inline-flex rounded-md border bg-background px-3 py-2 text-xs font-medium transition-all hover:bg-accent hover:text-accent-foreground">Đặt chính</button>
                                            </form>
                                        }

                                        <form asp-controller="Admin" asp-action="DeleteProductImage" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="imageId" value="@image.ImageId">
                                            <button type="submit" class="inline-flex rounded-md border border-rose-200 bg-rose-50 px-3 py-2 text-xs font-medium text-rose-700 transition-all hover:bg-rose-100">Xóa</button>
                                        </form>
                                    </div>
                                </article>
                            }
                        </div>
                    }
                </section>
            }
        </aside>
    </form>
</div>
