@model AdminDashboardViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Bảng điều khiển Admin";
    var maxTopProductUnits = Math.Max(Model.TopProducts.Select(item => item.UnitsSold).DefaultIfEmpty(1).Max(), 1);
}

<div class="space-y-6">
    <section class="rounded-2xl border border-border bg-card p-6 shadow-xs">
        <div class="grid grid-cols-1 gap-6 xl:grid-cols-12">
            <div class="xl:col-span-8">
                <span class="inline-flex rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold uppercase tracking-widest text-primary">Tổng quan vận hành</span>
                <h2 class="mt-4 text-3xl font-bold tracking-tight text-foreground sm:text-4xl">Dashboard admin dùng template Apex và dữ liệu thật của cửa hàng.</h2>
                <p class="mt-3 max-w-3xl text-sm leading-relaxed text-muted-foreground">
                    Doanh thu, đơn hàng, thanh toán, khách hàng và tồn kho được gom về một màn hình để theo dõi nhanh.
                </p>
            </div>
            <div class="xl:col-span-4">
                <div class="rounded-2xl border border-sidebar-border bg-sidebar p-5 text-sidebar-foreground shadow-sm">
                    <p class="text-[11px] font-semibold uppercase tracking-widest text-sidebar-foreground/50">Admin đang đăng nhập</p>
                    <h3 class="mt-3 text-xl font-semibold text-white">@(Model.AdminUser.FullName ?? Model.AdminUser.Username ?? "Administrator")</h3>
                    <p class="mt-1 text-sm text-sidebar-foreground/70">Role: @(string.IsNullOrWhiteSpace(Model.AdminUser.Role) ? "Admin" : Model.AdminUser.Role)</p>

                    <div class="mt-5 grid grid-cols-2 gap-3">
                        <div class="rounded-xl border border-white/10 bg-white/5 p-3">
                            <p class="text-[11px] uppercase tracking-widest text-sidebar-foreground/50">Đang xử lý</p>
                            <strong class="mt-2 block text-2xl font-semibold text-white">@Model.PendingOrders</strong>
                        </div>
                        <div class="rounded-xl border border-white/10 bg-white/5 p-3">
                            <p class="text-[11px] uppercase tracking-widest text-sidebar-foreground/50">Liên hệ</p>
                            <strong class="mt-2 block text-2xl font-semibold text-white">@Model.ContactMessagesCount</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
        <article class="rounded-xl border border-border bg-card p-5 shadow-xs">
            <div class="flex items-center justify-between">
                <span class="text-sm font-medium text-muted-foreground">Tổng doanh thu</span>
                <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10 text-primary">VND</span>
            </div>
            <strong class="mt-4 block text-3xl font-bold tracking-tight text-foreground">@Model.GrossRevenue.ToString("#,##0")</strong>
            <p class="mt-2 text-sm text-muted-foreground">Tháng này: @Model.RevenueThisMonth.ToString("#,##0") VND</p>
        </article>

        <article class="rounded-xl border border-border bg-card p-5 shadow-xs">
            <div class="flex items-center justify-between">
                <span class="text-sm font-medium text-muted-foreground">Đơn hàng</span>
                <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-blue-100 text-blue-700">@Model.OrdersThisMonth</span>
            </div>
            <strong class="mt-4 block text-3xl font-bold tracking-tight text-foreground">@Model.OrdersTotal</strong>
            <p class="mt-2 text-sm text-muted-foreground">@Model.PendingOrders đơn cần xử lý tiếp</p>
        </article>

        <article class="rounded-xl border border-border bg-card p-5 shadow-xs" id="admin-products">
            <div class="flex items-center justify-between">
                <span class="text-sm font-medium text-muted-foreground">Sản phẩm đang bán</span>
                <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-amber-100 text-amber-700">@Model.LowStockProductsCount</span>
            </div>
            <strong class="mt-4 block text-3xl font-bold tracking-tight text-foreground">@Model.ProductsActive</strong>
            <p class="mt-2 text-sm text-muted-foreground">@Model.LowStockProductsCount sản phẩm gần hết hàng</p>
        </article>

        <article class="rounded-xl border border-border bg-card p-5 shadow-xs" id="admin-customers">
            <div class="flex items-center justify-between">
                <span class="text-sm font-medium text-muted-foreground">Khách hàng</span>
                <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-emerald-100 text-emerald-700">@Model.NewCustomersThisMonth</span>
            </div>
            <strong class="mt-4 block text-3xl font-bold tracking-tight text-foreground">@Model.CustomersTotal</strong>
            <p class="mt-2 text-sm text-muted-foreground">@Model.NewCustomersThisMonth tài khoản mới trong tháng</p>
        </article>
    </section>

    <section class="grid grid-cols-1 gap-6 xl:grid-cols-12">
        <div class="xl:col-span-8" id="admin-orders">
            <div class="rounded-xl border border-border bg-card shadow-xs">
                <div class="flex flex-col gap-3 border-b border-border px-5 py-4 sm:flex-row sm:items-center sm:justify-between">
                    <div>
                        <h3 class="text-base font-semibold text-foreground">Đơn hàng gần đây</h3>
                        <p class="mt-1 text-sm text-muted-foreground">Các đơn mới nhất và trạng thái xử lý hiện tại.</p>
                    </div>
                    <span class="inline-flex w-fit rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold text-primary">@Model.OrdersThisMonth đơn trong tháng</span>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="border-b border-border text-left text-xs uppercase tracking-widest text-muted-foreground">
                                <th class="px-5 py-3 font-semibold">Đơn</th>
                                <th class="px-5 py-3 font-semibold">Khách hàng</th>
                                <th class="px-5 py-3 font-semibold">Thanh toán</th>
                                <th class="px-5 py-3 font-semibold">Ngày tạo</th>
                                <th class="px-5 py-3 font-semibold">Trạng thái</th>
                                <th class="px-5 py-3 text-right font-semibold">Tổng tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RecentOrders.Count == 0)
                            {
                                <tr>
                                    <td colspan="6" class="px-5 py-8 text-center text-sm text-muted-foreground">Chưa có đơn hàng.</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var order in Model.RecentOrders)
                                {
                                    var normalizedStatus = (order.Status ?? string.Empty).Trim().ToUpperInvariant();
                                    var statusClasses = normalizedStatus switch
                                    {
                                        "COMPLETED" => "bg-emerald-100 text-emerald-700",
                                        "CANCELLED" => "bg-rose-100 text-rose-700",
                                        "AWAITING PAYMENT" => "bg-amber-100 text-amber-700",
                                        "AWAITING STORE PAYMENT" => "bg-amber-100 text-amber-700",
                                        _ => "bg-blue-100 text-blue-700"
                                    };

                                    <tr class="border-b border-border last:border-b-0">
                                        <td class="px-5 py-4 font-semibold text-foreground">#@order.OrderId</td>
                                        <td class="px-5 py-4 text-muted-foreground">@order.CustomerName</td>
                                        <td class="px-5 py-4 text-muted-foreground">@order.PaymentMethod</td>
                                        <td class="px-5 py-4 text-muted-foreground">@(order.CreatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "--")</td>
                                        <td class="px-5 py-4">
                                            <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold @statusClasses">@order.Status</span>
                                        </td>
                                        <td class="px-5 py-4 text-right font-semibold text-foreground">@order.TotalAmount.ToString("#,##0") VND</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="xl:col-span-4">
            <div class="rounded-xl border border-border bg-card p-5 shadow-xs">
                <h3 class="text-base font-semibold text-foreground">Tình hình vận hành</h3>
                <p class="mt-1 text-sm text-muted-foreground">Các chỉ số cần theo dõi hằng ngày.</p>

                <div class="mt-5 space-y-3">
                    <div class="rounded-xl border border-border bg-accent/40 p-4">
                        <p class="text-sm text-muted-foreground">Giá trị đơn trung bình</p>
                        <strong class="mt-2 block text-2xl font-semibold text-foreground">@Model.AverageOrderValue.ToString("#,##0") VND</strong>
                    </div>
                    <div class="rounded-xl border border-border bg-accent/40 p-4">
                        <p class="text-sm text-muted-foreground">Tin nhắn liên hệ</p>
                        <strong class="mt-2 block text-2xl font-semibold text-foreground">@Model.ContactMessagesCount</strong>
                    </div>
                    <div class="rounded-xl border border-border bg-accent/40 p-4">
                        <p class="text-sm text-muted-foreground">Khách mới tháng này</p>
                        <strong class="mt-2 block text-2xl font-semibold text-foreground">@Model.NewCustomersThisMonth</strong>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="grid grid-cols-1 gap-6 xl:grid-cols-12">
        <div class="xl:col-span-6">
            <div class="rounded-xl border border-border bg-card p-5 shadow-xs">
                <h3 class="text-base font-semibold text-foreground">Phân bổ trạng thái đơn</h3>
                <p class="mt-1 text-sm text-muted-foreground">Tỷ lệ đơn hàng theo từng trạng thái.</p>

                <div class="mt-5 space-y-4">
                    @if (Model.OrderStatusItems.Count == 0)
                    {
                        <p class="text-sm text-muted-foreground">Chưa có dữ liệu trạng thái đơn.</p>
                    }
                    else
                    {
                        foreach (var item in Model.OrderStatusItems)
                        {
                            <div class="rounded-xl border border-border bg-background p-4">
                                <div class="mb-3 flex items-center justify-between gap-3">
                                    <strong class="text-sm font-semibold text-foreground">@item.Label</strong>
                                    <span class="text-sm text-muted-foreground">@item.Count đơn</span>
                                </div>
                                <div class="h-2 overflow-hidden rounded-full bg-accent">
                                    <div class="h-full rounded-full bg-primary" style="width:@item.Percentage.ToString(System.Globalization.CultureInfo.InvariantCulture)%"></div>
                                </div>
                                <p class="mt-2 text-xs font-medium text-muted-foreground">@item.Percentage.ToString("0.#")%</p>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="xl:col-span-6">
            <div class="rounded-xl border border-border bg-card p-5 shadow-xs">
                <h3 class="text-base font-semibold text-foreground">Cơ cấu thanh toán</h3>
                <p class="mt-1 text-sm text-muted-foreground">Các phương thức thanh toán khách đang sử dụng.</p>

                <div class="mt-5 space-y-4">
                    @if (Model.PaymentMethodItems.Count == 0)
                    {
                        <p class="text-sm text-muted-foreground">Chưa có dữ liệu thanh toán.</p>
                    }
                    else
                    {
                        foreach (var item in Model.PaymentMethodItems)
                        {
                            <div class="rounded-xl border border-border bg-background p-4">
                                <div class="mb-3 flex items-center justify-between gap-3">
                                    <strong class="text-sm font-semibold text-foreground">@item.Label</strong>
                                    <span class="text-sm text-muted-foreground">@item.Count giao dịch</span>
                                </div>
                                <div class="h-2 overflow-hidden rounded-full bg-accent">
                                    <div class="h-full rounded-full bg-amber-500" style="width:@item.Percentage.ToString(System.Globalization.CultureInfo.InvariantCulture)%"></div>
                                </div>
                                <p class="mt-2 text-xs font-medium text-muted-foreground">@item.Percentage.ToString("0.#")%</p>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </section>

    <section class="grid grid-cols-1 gap-6 xl:grid-cols-12">
        <div class="xl:col-span-6" id="admin-inventory">
            <div class="rounded-xl border border-border bg-card p-5 shadow-xs">
                <h3 class="text-base font-semibold text-foreground">Cảnh báo tồn kho thấp</h3>
                <p class="mt-1 text-sm text-muted-foreground">Những sản phẩm nên nhập bổ sung trước.</p>

                <div class="mt-5 space-y-3">
                    @if (Model.LowStockProducts.Count == 0)
                    {
                        <p class="text-sm text-muted-foreground">Hiện chưa có sản phẩm tồn kho thấp.</p>
                    }
                    else
                    {
                        foreach (var product in Model.LowStockProducts)
                        {
                            var stockClasses = product.Stock <= 2 ? "bg-rose-100 text-rose-700" : "bg-amber-100 text-amber-700";

                            <article class="flex flex-col gap-3 rounded-xl border border-border bg-background p-4 sm:flex-row sm:items-center sm:justify-between">
                                <div>
                                    <strong class="text-sm font-semibold text-foreground">@product.Name</strong>
                                    <p class="mt-1 text-sm text-muted-foreground">@product.Brand · @product.CategoryName</p>
                                </div>
                                <div class="sm:text-right">
                                    <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold @stockClasses">Tồn kho @product.Stock</span>
                                    <p class="mt-2 text-sm font-semibold text-foreground">@product.FinalPrice.ToString("#,##0") VND</p>
                                </div>
                            </article>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="xl:col-span-6">
            <div class="rounded-xl border border-border bg-card p-5 shadow-xs">
                <h3 class="text-base font-semibold text-foreground">Sản phẩm bán chạy</h3>
                <p class="mt-1 text-sm text-muted-foreground">Các sản phẩm có sản lượng và doanh thu tốt nhất.</p>

                <div class="mt-5 space-y-4">
                    @if (Model.TopProducts.Count == 0)
                    {
                        <p class="text-sm text-muted-foreground">Chưa có dữ liệu xếp hạng bán hàng.</p>
                    }
                    else
                    {
                        foreach (var product in Model.TopProducts)
                        {
                            var width = decimal.Round((decimal)product.UnitsSold * 100m / maxTopProductUnits, 1, MidpointRounding.AwayFromZero);

                            <article class="rounded-xl border border-border bg-background p-4">
                                <div class="mb-3 flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                                    <div>
                                        <strong class="text-sm font-semibold text-foreground">@product.Name</strong>
                                        <p class="mt-1 text-sm text-muted-foreground">@product.Brand</p>
                                    </div>
                                    <div class="sm:text-right">
                                        <p class="text-sm font-medium text-foreground">@product.UnitsSold sản phẩm</p>
                                        <p class="text-sm text-muted-foreground">@product.Revenue.ToString("#,##0") VND</p>
                                    </div>
                                </div>
                                <div class="h-2 overflow-hidden rounded-full bg-accent">
                                    <div class="h-full rounded-full bg-primary" style="width:@width.ToString(System.Globalization.CultureInfo.InvariantCulture)%"></div>
                                </div>
                            </article>
                        }
                    }
                </div>
            </div>
        </div>
    </section>
</div>
