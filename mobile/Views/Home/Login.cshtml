@model LoginViewModel

@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="breadcrumb-area">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="breadcrumb-wrap">
                    <nav aria-label="breadcrumb">
                        <ul class="breadcrumb">
                            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Trang chủ</a></li>
                            <li class="breadcrumb-item active" aria-current="page">Đăng nhập</li>
                        </ul>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="login-wrapper pb-70">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12 col-lg-8 col-xl-6 offset-lg-2 offset-xl-3">
                <main id="primary" class="site-main">
                    <div class="user-login surface-panel">
                        <div class="section-title text-center">
                            <h3>Đăng nhập tài khoản</h3>
                        </div>

                        <div class="login-form">
                            <form asp-action="Login" method="post">
                                @Html.AntiForgeryToken()
                                <input asp-for="ReturnUrl" type="hidden">

                                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                                <div class="form-group row align-items-center mb-4">
                                    <label asp-for="EmailOrUsername" class="col-12 col-md-4 col-form-label">Email hoặc tên đăng nhập</label>
                                    <div class="col-12 col-md-8">
                                        <input asp-for="EmailOrUsername" class="form-control" placeholder="Nhập email hoặc username">
                                        <span asp-validation-for="EmailOrUsername" class="text-danger"></span>
                                    </div>
                                </div>

                                <div class="form-group row align-items-center mb-4">
                                    <label asp-for="Password" class="col-12 col-md-4 col-form-label">Mật khẩu</label>
                                    <div class="col-12 col-md-8">
                                        <div class="password-field-group">
                                            <input asp-for="Password" class="form-control" placeholder="Nhập mật khẩu">
                                            <button type="button" class="password-toggle-button" data-password-toggle="#Password" aria-label="Hiển thị mật khẩu">
                                                <i class="fa fa-eye"></i>
                                            </button>
                                        </div>
                                        <span asp-validation-for="Password" class="text-danger"></span>
                                    </div>
                                </div>

                                <div class="login-box mt-5 text-center">
                                    <button type="submit" class="btn btn-secondary mb-4 mt-2">Đăng nhập</button>
                                </div>

                                <div class="text-center pt-20 top-bordered">
                                    <p>Chưa có tài khoản? <a href="@Url.Action("Register", "Account")">Tạo tài khoản tại đây</a>.</p>
                                </div>
                            </form>
                        </div>
                    </div>
                </main>
            </div>
        </div>
    </div>
</div>

<div class="scroll-top not-visible">
    <i class="fa fa-angle-up"></i>
</div>
