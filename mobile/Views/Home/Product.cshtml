@model ProductPageViewModel

<style>
    .product-detail-variants {
        display: grid;
        gap: 12px;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        margin-top: 16px;
    }

    .product-detail-variant-card {
        background: #fff;
        border: 1px solid #e7e7e7;
        border-radius: 8px;
        padding: 14px 16px;
    }

    .product-detail-variant-name {
        color: #111;
        display: block;
        font-size: 16px;
        font-weight: 600;
        line-height: 1.4;
        margin-bottom: 6px;
    }

    .product-detail-variant-price {
        color: #ff5517;
        display: block;
        font-size: 18px;
        font-weight: 700;
        line-height: 1.4;
    }

    .product-detail-variant-stock {
        color: #666;
        display: block;
        font-size: 13px;
        line-height: 1.5;
        margin-top: 4px;
    }
</style>

@{
    ViewData["Title"] = Model.Product.Name;
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";

    string description = string.IsNullOrWhiteSpace(Model.Product.Description)
        ? "San pham dang duoc dong bo tu database. Thong tin chi tiet se duoc cap nhat them khi co du lieu day du."
        : Model.Product.Description.Trim();

    string categoryName = Model.Product.Category?.CategoryName ?? "San pham";

    static List<string> RelatedImages(Product product)
    {
        var urls = product.ProductImages
            .Where(image => !string.IsNullOrWhiteSpace(image.ImageUrl))
            .OrderByDescending(image => image.IsMain ?? false)
            .Select(image => image.ImageUrl!.Trim())
            .ToList();

        if (!string.IsNullOrWhiteSpace(product.Thumbnail))
        {
            urls.Insert(0, product.Thumbnail.Trim());
        }

        var distinctUrls = urls
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        if (distinctUrls.Count == 0)
        {
            distinctUrls.Add("~/assets/img/product/product-1.jpg");
        }

        return distinctUrls;
    }

    static decimal RelatedFinalPrice(Product product)
    {
        var discount = product.Discount ?? 0m;
        return discount > 0m ? product.Price * (1m - (discount / 100m)) : product.Price;
    }
}

<div class="breadcrumb-area mb-30">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="breadcrumb-wrap">
                    <nav aria-label="breadcrumb">
                        <ul class="breadcrumb">
                            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
                            <li class="breadcrumb-item"><a href="@Url.Action("Shop", "Shop")">Shop</a></li>
                            <li class="breadcrumb-item"><a href="@Url.Action("Shop", "Shop", new { category = categoryName })">@categoryName</a></li>
                            <li class="breadcrumb-item active" aria-current="page">@Model.Product.Name</li>
                        </ul>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="product-details-main-wrapper pb-50">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-5">
                <div class="product-large-slider mb-20">
                    @foreach (var imageUrl in Model.ImageUrls)
                    {
                        <div class="pro-large-img">
                            <img src="@Url.Content(imageUrl)" alt="@Model.Product.Name" />
                            <div class="img-view">
                                <a class="img-popup" href="@Url.Content(imageUrl)"><i class="fa fa-search"></i></a>
                            </div>
                        </div>
                    }
                </div>
                <div class="pro-nav">
                    @foreach (var imageUrl in Model.ImageUrls)
                    {
                        <div class="pro-nav-thumb">
                            <img src="@Url.Content(imageUrl)" alt="@Model.Product.Name" />
                        </div>
                    }
                </div>
            </div>

            <div class="col-lg-7">
                <div class="product-details-inner">
                    <div class="product-details-contentt">
                        <div class="pro-details-name mb-10">
                            <h3>@Model.Product.Name</h3>
                        </div>

                        <div class="pro-details-review mb-20">
                            <ul>
                                <li>
                                    @for (var star = 1; star <= 5; star++)
                                    {
                                        var cssClass = star <= Math.Round(Model.AverageRating, MidpointRounding.AwayFromZero) ? "fa fa-star" : "fa fa-star-o";
                                        <span><i class="@cssClass"></i></span>
                                    }
                                </li>
                                <li><a href="#tab_review">@Model.ReviewCount reviews</a></li>
                            </ul>
                        </div>

                        <div class="price-box mb-15">
                            <span class="regular-price">
                                <span class="special-price">@Model.FinalPrice.ToString("#,##0") VND</span>
                            </span>
                            @if (Model.OriginalPrice.HasValue)
                            {
                                <span class="old-price"><del>@Model.OriginalPrice.Value.ToString("#,##0") VND</del></span>
                            }
                        </div>

                        <div class="product-detail-sort-des pb-20">
                            <p>@description</p>
                        </div>

                        <div class="pro-details-list pt-20">
                            <ul>
                                @foreach (var item in Model.OverviewItems)
                                {
                                    <li><span>@item.Label :</span>@item.Value</li>
                                }
                                <li><span>Ma san pham :</span>#SP-@Model.Product.ProductId</li>
                                <li><span>Danh gia trung binh :</span>@Model.AverageRating.ToString("0.0")/5</li>
                            </ul>
                        </div>

                        @if (Model.Variants.Count > 0)
                        {
                            <div class="product-availabily-option mt-15 mb-15">
                                <h3>Phien ban dang co</h3>
                                <div class="product-detail-variants">
                                    @foreach (var variant in Model.Variants)
                                    {
                                        var variantPrice = variant.Price ?? Model.FinalPrice;
                                        var stockText = (variant.Stock ?? 0) > 0
                                            ? $"Con {(variant.Stock ?? 0)} san pham"
                                            : "Tam het hang";

                                        <div class="product-detail-variant-card">
                                            <span class="product-detail-variant-name">@variant.VariantName</span>
                                            <span class="product-detail-variant-price">@variantPrice.ToString("#,##0") VND</span>
                                            <span class="product-detail-variant-stock">@stockText</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        <div class="pro-quantity-box mb-30">
                            <form asp-action="AddToCart" asp-controller="Checkout" method="post" class="qty-boxx product-primary-cart">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@Model.Product.ProductId">
                                <input type="hidden" name="returnUrl" value="@returnUrl">
                                <label>qty :</label>
                                <input type="number" name="quantity" placeholder="1" value="1" min="1" max="@(Math.Max(Model.Product.Stock ?? 1, 1))">
                                <button type="submit" class="btn-cart lg-btn" disabled="@(Model.InStock ? null : "disabled")">add to cart</button>
                            </form>
                        </div>

                        <div class="useful-links mb-20">
                            <ul class="product-secondary-actions">
                                <li>
                                    <form asp-action="AddToWishlist" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="productId" value="@Model.Product.ProductId">
                                        <input type="hidden" name="returnUrl" value="@returnUrl">
                                        <button type="submit" class="link-style-button"><i class="fa fa-heart-o"></i>add to wish list</button>
                                    </form>
                                </li>
                                <li>
                                    <form asp-action="AddToCompare" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="productId" value="@Model.Product.ProductId">
                                        <input type="hidden" name="returnUrl" value="@returnUrl">
                                        <button type="submit" class="link-style-button"><i class="fa fa-refresh"></i>compare this product</button>
                                    </form>
                                </li>
                            </ul>
                        </div>

                        <div class="tag-line mb-20">
                            <label>tag :</label>
                            <a href="@Url.Action("Shop", "Shop", new { category = categoryName })">@categoryName</a>
                            @if (!string.IsNullOrWhiteSpace(Model.Product.Brand))
                            {
                                <text>, <a href="@Url.Action("Shop", "Shop", new { brand = Model.Product.Brand })">@Model.Product.Brand</a></text>
                            }
                        </div>

                        <div class="pro-social-sharing">
                            <label>share :</label>
                            <ul>
                                <li class="list-inline-item">
                                    <a href="#" class="bg-facebook" title="Facebook">
                                        <i class="fa fa-facebook"></i>
                                        <span>facebook</span>
                                    </a>
                                </li>
                                <li class="list-inline-item">
                                    <a href="#" class="bg-twitter" title="Twitter">
                                        <i class="fa fa-twitter"></i>
                                        <span>twitter</span>
                                    </a>
                                </li>
                                <li class="list-inline-item">
                                    <a href="#" class="bg-google" title="Google Plus">
                                        <i class="fa fa-google-plus"></i>
                                        <span>google</span>
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="product-details-reviews pb-30">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-12">
                <div class="product-info mt-half">
                    <ul class="nav nav-pills justify-content-center" id="pills-tab" role="tablist">
                        <li class="nav-item">
                            <button type="button" class="nav-link active" id="nav_desctiption" data-bs-toggle="pill" data-bs-target="#tab_description" role="tab" aria-controls="tab_description" aria-selected="true">Description</button>
                        </li>
                        <li class="nav-item">
                            <button type="button" class="nav-link" id="nav_specs" data-bs-toggle="pill" data-bs-target="#tab_specs" role="tab" aria-controls="tab_specs" aria-selected="false">Thong so</button>
                        </li>
                        <li class="nav-item">
                            <button type="button" class="nav-link" id="nav_review" data-bs-toggle="pill" data-bs-target="#tab_review" role="tab" aria-controls="tab_review" aria-selected="false">Reviews (@Model.ReviewCount)</button>
                        </li>
                    </ul>
                    <div class="tab-content">
                        <div class="tab-pane fade show active" id="tab_description" role="tabpanel" aria-labelledby="nav_desctiption">
                            <p>@description</p>

                            <div class="row mt-30">
                                @foreach (var item in Model.OverviewItems)
                                {
                                    <div class="col-md-4 col-sm-6 mb-20">
                                        <div class="pro-details-list">
                                            <ul>
                                                <li><span>@item.Label :</span>@item.Value</li>
                                            </ul>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="tab-pane fade" id="tab_specs" role="tabpanel" aria-labelledby="nav_specs">
                            <div class="table-responsive">
                                <table class="table table-striped table-bordered">
                                    <tbody>
                                        @foreach (var spec in Model.SpecificationItems)
                                        {
                                            <tr>
                                                <td style="width: 28%;"><strong>@spec.Label</strong></td>
                                                <td>@spec.Value</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="tab_review" role="tabpanel" aria-labelledby="nav_review">
                            <div class="product-review">
                                @if (Model.Reviews.Count == 0)
                                {
                                    <div class="alert alert-info mb-0">
                                        San pham chua co danh gia nao trong database.
                                    </div>
                                }
                                else
                                {
                                    <div class="customer-review">
                                        @foreach (var review in Model.Reviews)
                                        {
                                            var reviewerName = review.User?.FullName
                                                ?? review.User?.Username
                                                ?? $"User {review.UserId}";

                                            <table class="table table-striped table-bordered mb-20">
                                                <tbody>
                                                    <tr>
                                                        <td><strong>@reviewerName</strong></td>
                                                        <td class="text-end">@((review.CreatedAt ?? DateTime.Now).ToString("dd/MM/yyyy"))</td>
                                                    </tr>
                                                    <tr>
                                                        <td colspan="2">
                                                            <p>@(string.IsNullOrWhiteSpace(review.Comment) ? "Nguoi dung chua de lai noi dung danh gia." : review.Comment)</p>
                                                            <div class="product-ratings">
                                                                <ul class="ratting d-flex mt-2">
                                                                    @for (var star = 1; star <= 5; star++)
                                                                    {
                                                                        var cssClass = star <= (review.Rating ?? 0) ? "fa fa-star" : "fa fa-star-o";
                                                                        <li><i class="@cssClass"></i></li>
                                                                    }
                                                                </ul>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (Model.RelatedProducts.Count > 0)
{
    <div class="related-product-area mb-40">
        <div class="container-fluid">
            <div class="section-title">
                <h3><span>Related</span> product </h3>
            </div>
            <div class="flash-sale-active4 owl-carousel owl-arrow-style">
                @foreach (var relatedProduct in Model.RelatedProducts)
                {
                    var productUrl = Url.Action("Product", "Shop", new { id = relatedProduct.ProductId });
                    var relatedImages = RelatedImages(relatedProduct);
                    var primaryImage = relatedImages.First();
                    var secondaryImage = relatedImages.Skip(1).FirstOrDefault() ?? primaryImage;
                    var finalPrice = RelatedFinalPrice(relatedProduct);

                    <div class="product-item mb-30">
                        <div class="product-thumb">
                            <a href="@productUrl">
                                <img src="@Url.Content(primaryImage)" class="pri-img" alt="@relatedProduct.Name">
                                <img src="@Url.Content(secondaryImage)" class="sec-img" alt="@relatedProduct.Name">
                            </a>
                            <div class="box-label">
                                @if (relatedProduct.Discount.HasValue && relatedProduct.Discount.Value > 0)
                                {
                                    <div class="label-product label_sale">
                                        <span>-@relatedProduct.Discount.Value.ToString("0")%</span>
                                    </div>
                                }
                                else
                                {
                                    <div class="label-product label_new">
                                        <span>new</span>
                                    </div>
                                }
                            </div>
                            <div class="action-links action-links-forms">
                                <form asp-action="AddToWishlist" method="post" class="icon-action-form" title="Wishlist">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@relatedProduct.ProductId">
                                    <input type="hidden" name="returnUrl" value="@returnUrl">
                                    <button type="submit" class="icon-action-button"><i class="lnr lnr-heart"></i></button>
                                </form>
                                <form asp-action="AddToCompare" method="post" class="icon-action-form" title="Compare">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@relatedProduct.ProductId">
                                    <input type="hidden" name="returnUrl" value="@returnUrl">
                                    <button type="submit" class="icon-action-button"><i class="lnr lnr-sync"></i></button>
                                </form>
                                <a href="@productUrl" title="View Product"><i class="lnr lnr-magnifier"></i></a>
                            </div>
                        </div>
                        <div class="product-caption">
                            <div class="manufacture-product">
                                <p><a href="@Url.Action("Shop", "Shop", new { brand = relatedProduct.Brand })">@(relatedProduct.Brand ?? relatedProduct.Category?.CategoryName ?? "San pham")</a></p>
                            </div>
                            <div class="product-name">
                                <h4><a href="@productUrl">@relatedProduct.Name</a></h4>
                            </div>
                            <div class="ratings">
                                <span class="yellow"><i class="lnr lnr-star"></i></span>
                                <span class="yellow"><i class="lnr lnr-star"></i></span>
                                <span class="yellow"><i class="lnr lnr-star"></i></span>
                                <span class="yellow"><i class="lnr lnr-star"></i></span>
                                <span><i class="lnr lnr-star"></i></span>
                            </div>
                            <div class="price-box">
                                <span class="regular-price">@finalPrice.ToString("#,##0") VND</span>
                                @if (relatedProduct.Discount.HasValue && relatedProduct.Discount.Value > 0)
                                {
                                    <span class="old-price"><del>@relatedProduct.Price.ToString("#,##0") VND</del></span>
                                }
                            </div>
                            <a class="btn-cart" href="@productUrl">xem chi tiet</a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

<div class="scroll-top not-visible">
    <i class="fa fa-angle-up"></i>
</div>
