@model IReadOnlyList<BlogArticleViewModel>

@{
    ViewData["Title"] = "Tin tức";
}

<div class="breadcrumb-area mb-30">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="breadcrumb-wrap">
                    <nav aria-label="breadcrumb">
                        <ul class="breadcrumb">
                            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Trang chủ</a></li>
                            <li class="breadcrumb-item active" aria-current="page">Tin tức</li>
                        </ul>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="blog-area-wrapper pt-30 pb-65">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-12">
                <div class="blog-wrapper-inner column5">
                    <div class="row">
                        @foreach (var article in Model)
                        {
                            var articleUrl = Url.Action("BlogDetails", "Home", new { id = article.Id });

                            <div class="col-sm-6 col-lg-4 col-xl-3">
                                <article class="single-blogg-item mb-30">
                                    <div class="blogg-thumb">
                                        <a href="@articleUrl">
                                            <img src="@Url.Content(article.ImageUrl)" alt="@article.Title">
                                        </a>
                                    </div>
                                    <div class="blogg-content">
                                        <span class="post-date">@article.CreatedAt.ToString("dd/MM/yyyy") · @article.Author</span>
                                        <h5><a href="@articleUrl">@article.Title</a></h5>
                                        <p>@article.Summary</p>
                                        <a class="read-more-link" href="@articleUrl">Đọc tiếp</a>
                                    </div>
                                </article>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="scroll-top not-visible">
    <i class="fa fa-angle-up"></i>
</div>
