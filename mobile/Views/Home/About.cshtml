@{ ViewData["Title"] = "Giới thiệu"; }

<div class="breadcrumb-area mb-30">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="breadcrumb-wrap">
                    <nav aria-label="breadcrumb">
                        <ul class="breadcrumb">
                            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Trang chủ</a></li>
                            <li class="breadcrumb-item active" aria-current="page">Giới thiệu</li>
                        </ul>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>

<main class="about-page pb-40">
    <section class="pb-30">
        <div class="container-fluid">
            <div class="about-hero-card">
                <div class="row align-items-center">
                    <div class="col-lg-7 mb-30 mb-lg-0">
                        <div class="about-hero-content">
                            <span class="about-kicker">Sinrato Store</span>
                            <h1>Nền tảng mua sắm công nghệ rõ ràng, nhanh và đáng tin cậy.</h1>
                            <p class="about-lead">
                                Trang giới thiệu được làm lại theo hướng chuyên nghiệp hơn để phản ánh đúng một website bán hàng công nghệ:
                                giao diện rõ ràng, thông tin minh bạch, quy trình mua hàng đầy đủ và sẵn sàng mở rộng vận hành thực tế.
                            </p>
                            <div class="about-hero-actions">
                                <a href="@Url.Action("Shop", "Shop")" class="about-primary-btn">Khám phá sản phẩm</a>
                                <a href="@Url.Action("Contact", "Home")" class="about-secondary-btn">Liên hệ tư vấn</a>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-5">
                        <div class="about-hero-media position-relative">
                            <img src="~/assets/img/banner/img1-top-sinrato1.jpg" alt="Sinrato store" class="about-hero-image">
                            <div class="about-hero-badge">
                                <span>Trọng tâm phát triển</span>
                                <strong>Mua hàng liền mạch từ tìm kiếm đến thanh toán QR ngân hàng.</strong>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="pb-30">
        <div class="container-fluid">
            <div class="row">
                <div class="col-lg-6 mb-30">
                    <div class="about-section-card">
                        <h2 class="about-grid-title">Chúng tôi đang xây dựng gì</h2>
                        <p class="about-grid-text">
                            Đây là website thương mại điện tử tập trung vào nhóm sản phẩm công nghệ, với các trang chính đã được tổ chức rõ:
                            cửa hàng, chi tiết sản phẩm, giỏ hàng, yêu thích, so sánh, thanh toán và quản lý tài khoản.
                        </p>
                    </div>
                </div>
                <div class="col-lg-6 mb-30">
                    <div class="about-section-card">
                        <h3>Điểm trọng tâm hiện tại</h3>
                        <ul class="about-list">
                            <li>Tối ưu trải nghiệm xem sản phẩm và lọc theo danh mục, giá, thương hiệu.</li>
                            <li>Hoàn thiện luồng mua hàng thực tế từ thêm giỏ hàng đến đặt đơn.</li>
                            <li>Hỗ trợ thanh toán QR ngân hàng và các phương thức thanh toán linh hoạt.</li>
                            <li>Chuẩn hóa giao diện tiếng Việt, trạng thái active menu và điều hướng toàn site.</li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 col-xl-3 mb-30">
                    <div class="about-metric-card">
                        <span>Danh mục</span>
                        <strong>Shop</strong>
                        <p>Hiển thị rõ bộ lọc, sản phẩm nổi bật và truy cập nhanh tới các nhóm hàng chính.</p>
                    </div>
                </div>
                <div class="col-md-6 col-xl-3 mb-30">
                    <div class="about-metric-card">
                        <span>Trải nghiệm</span>
                        <strong>Product</strong>
                        <p>Thông tin cấu hình, hình ảnh, giá bán, phiên bản và khối mua hàng được trình bày đồng bộ.</p>
                    </div>
                </div>
                <div class="col-md-6 col-xl-3 mb-30">
                    <div class="about-metric-card">
                        <span>Thanh toán</span>
                        <strong>Checkout</strong>
                        <p>Đặt hàng theo luồng rõ ràng với QR ngân hàng, thanh toán tại cửa hàng hoặc COD.</p>
                    </div>
                </div>
                <div class="col-md-6 col-xl-3 mb-30">
                    <div class="about-metric-card">
                        <span>Tài khoản</span>
                        <strong>Account</strong>
                        <p>Theo dõi thông tin cá nhân, trạng thái mua hàng, giỏ hàng và danh sách yêu thích.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="pb-30">
        <div class="container-fluid">
            <div class="row align-items-stretch">
                <div class="col-lg-4 mb-30">
                    <div class="about-process-card">
                        <div class="about-process-number">01</div>
                        <h4>Khám phá sản phẩm</h4>
                        <p>Người dùng tìm kiếm và lọc sản phẩm theo danh mục, thương hiệu, mức giá để rút ngắn thời gian ra quyết định.</p>
                    </div>
                </div>
                <div class="col-lg-4 mb-30">
                    <div class="about-process-card">
                        <div class="about-process-number">02</div>
                        <h4>So sánh và lựa chọn</h4>
                        <p>Trang chi tiết và so sánh được làm rõ hơn để người mua đối chiếu cấu hình, giá bán và ưu đãi trước khi thêm giỏ hàng.</p>
                    </div>
                </div>
                <div class="col-lg-4 mb-30">
                    <div class="about-process-card">
                        <div class="about-process-number">03</div>
                        <h4>Đặt hàng và thanh toán</h4>
                        <p>Luồng checkout hỗ trợ nhiều phương thức thanh toán và điều hướng rõ tới bước xác nhận QR hoặc hoàn tất đơn hàng.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="pb-30">
        <div class="container-fluid">
            <div class="row align-items-stretch">
                <div class="col-lg-4 mb-30">
                    <div class="about-value-card">
                        <h4>Giao diện có hệ thống</h4>
                        <p>Màu sắc, bo góc, trạng thái menu và card nội dung được đồng bộ để toàn bộ site nhìn chuyên nghiệp hơn.</p>
                    </div>
                </div>
                <div class="col-lg-4 mb-30">
                    <div class="about-value-card">
                        <h4>Nội dung phục vụ bán hàng</h4>
                        <p>Mọi khối hiển thị được sắp lại theo mục tiêu bán hàng: giúp khách hiểu sản phẩm nhanh, thao tác ít và đi đúng luồng.</p>
                    </div>
                </div>
                <div class="col-lg-4 mb-30">
                    <div class="about-value-card">
                        <h4>Sẵn sàng mở rộng thực tế</h4>
                        <p>Cấu trúc MVC đã tách nghiệp vụ rõ hơn để dễ phát triển tiếp phần quản trị, đơn hàng, đối soát thanh toán và báo cáo.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section>
        <div class="container-fluid">
            <div class="about-cta-card">
                <h3>Cần xem sản phẩm hoặc trao đổi trực tiếp?</h3>
                <p>
                    Bạn có thể vào ngay trang cửa hàng để duyệt danh mục sản phẩm, hoặc chuyển sang trang liên hệ nếu muốn tư vấn nhanh
                    về cấu hình, đặt hàng và phương thức thanh toán phù hợp.
                </p>
                <div class="about-hero-actions">
                    <a href="@Url.Action("Shop", "Shop")" class="about-primary-btn">Vào cửa hàng</a>
                    <a href="@Url.Action("Contact", "Home")" class="about-secondary-btn">Mở trang liên hệ</a>
                </div>
            </div>
        </div>
    </section>
</main>
