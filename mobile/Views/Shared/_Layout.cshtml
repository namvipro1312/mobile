
@using Microsoft.AspNetCore.Http
@using Microsoft.EntityFrameworkCore
@using System.Text.Json
@inject MobileContext Db

@functions {
    private sealed class HeaderCategoryItem
    {
        public string Name { get; init; } = string.Empty;

        public int ProductCount { get; init; }
    }
}

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    var currentKeyword = Context.Request.Query["keyword"].ToString();
    var currentUserId = Context.Session.GetInt32("CurrentUserId");
    var currentSearchCategory = Context.Request.Query["category"].FirstOrDefault() ?? string.Empty;
    var currentCategorySelections = Context.Request.Query["category"]
        .Where(value => !string.IsNullOrWhiteSpace(value))
        .Select(value => value?.Trim() ?? string.Empty)
        .ToHashSet(StringComparer.OrdinalIgnoreCase);

    var currentCategoryName = ViewData["CurrentCategoryName"]?.ToString();
    if (!string.IsNullOrWhiteSpace(currentCategoryName))
    {
        currentCategorySelections.Add(currentCategoryName);

        if (string.IsNullOrWhiteSpace(currentSearchCategory))
        {
            currentSearchCategory = currentCategoryName;
        }
    }

    bool IsCurrentPage(string controller, params string[] actions) =>
        string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase) &&
        actions.Any(action => string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase));

    string MenuClass(params string[] keys)
    {
        foreach (var key in keys)
        {
            var parts = key.Split(':', 2, StringSplitOptions.TrimEntries);
            if (parts.Length == 2 && IsCurrentPage(parts[0], parts[1]))
            {
                return "active-menu";
            }
        }

        return string.Empty;
    }
    string CategoryClass(string categoryName) => currentCategorySelections.Contains(categoryName) ? "is-active-category" : string.Empty;

    var headerCategories = await Db.Categories
        .AsNoTracking()
        .Select(category => new HeaderCategoryItem
        {
            Name = category.CategoryName,
            ProductCount = category.Products.Count(product => product.IsActive != false)
        })
        .OrderByDescending(category => category.ProductCount)
        .ThenBy(category => category.Name)
        .Take(10)
        .ToListAsync();

    var currentUser = currentUserId.HasValue
        ? await Db.Users.AsNoTracking().FirstOrDefaultAsync(user => user.UserId == currentUserId.Value)
        : null;

    var wishlistCount = currentUserId.HasValue
        ? await Db.Wishlists.AsNoTracking().CountAsync(item => item.UserId == currentUserId.Value)
        : 0;

    var cartPreviewItems = currentUserId.HasValue
        ? await Db.CartItems
            .AsNoTracking()
            .Include(item => item.Product!)
                .ThenInclude(product => product.ProductImages)
            .Include(item => item.Product!)
                .ThenInclude(product => product.Category)
            .Include(item => item.Cart)
            .Where(item => item.Cart!.UserId == currentUserId.Value && item.Product != null && item.Product.IsActive != false)
            .OrderByDescending(item => item.CartItemId)
            .Take(3)
            .ToListAsync()
        : [];

    var cartCount = cartPreviewItems.Sum(item => item.Quantity ?? 0);
    var cartSubtotal = cartPreviewItems.Sum(item => (item.Price ?? 0m) * Math.Max(item.Quantity ?? 1, 1));

    var compareIdsRaw = Context.Session.GetString("CompareProductIds");
    var compareCount = 0;
    if (!string.IsNullOrWhiteSpace(compareIdsRaw))
    {
        try
        {
            compareCount = (JsonSerializer.Deserialize<List<int>>(compareIdsRaw) ?? []).Count;
        }
        catch
        {
            compareCount = 0;
        }
    }
}

